# BNB Chain Testnet defaults (chainId 97). Mainnet is intentionally not supported.
NEXT_PUBLIC_NETWORK=97
NEXT_PUBLIC_RPC_URL=https://bsc-testnet-rpc.publicnode.com

# Testnet contract addresses — fill in after running scripts/deploy.js on bscTestnet.
NEXT_PUBLIC_LAUNCHPAD_ADDRESS=
NEXT_PUBLIC_TOKEN_FACTORY_ADDRESS=
NEXT_PUBLIC_VESTING_ADDRESS=

# Server-only: comma-separated lowercase addresses approved through KYC.
# Mirrors EXEMPT_ADDRESSES — admin manages manually for MVP. Swap this lookup
# for a Sumsub/Persona/etc. integration later without changing the API surface.
KYC_VERIFIED_ADDRESSES=

# WalletConnect v2 — get a Project ID from https://cloud.walletconnect.com.
# Required for the "WalletConnect" option in the wallet picker. The picker
# falls back to disabled state if this is missing.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
