{
  "name": "crypto-launchpad",
  "version": "1.0.0",
  "description": "Pinksale-like crypto launchpad platform",
  "private": true,
  "workspaces": [
    "packages/contracts",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/frontend",
    "build": "npm run build --workspace=packages/frontend",
    "test": "npm run test --workspace=packages/contracts && npm run test --workspace=packages/frontend",
    "contracts:compile": "npm run compile --workspace=packages/contracts",
    "contracts:deploy": "npm run deploy --workspace=packages/contracts",
    "contracts:test": "npm run test --workspace=packages/contracts"
  },
  "devDependencies": {
    "workspaces": "*"
  }
}
